{
  "openapi": "3.0.4",
  "info": {
    "title": "Microondas.Api",
    "version": "1.0"
  },
  "paths": {
    "/api/Auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Microwave/start": {
      "post": {
        "tags": [
          "Microwave"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StartHeatingRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/StartHeatingRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/StartHeatingRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Microwave/quick-start": {
      "post": {
        "tags": [
          "Microwave"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Microwave/start-program/{programName}": {
      "post": {
        "tags": [
          "Microwave"
        ],
        "parameters": [
          {
            "name": "programName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Microwave/pause-cancel": {
      "post": {
        "tags": [
          "Microwave"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Microwave/resume": {
      "post": {
        "tags": [
          "Microwave"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Microwave/tick": {
      "post": {
        "tags": [
          "Microwave"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Microwave/current": {
      "get": {
        "tags": [
          "Microwave"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Microwave/clear": {
      "post": {
        "tags": [
          "Microwave"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Programs": {
      "get": {
        "tags": [
          "Programs"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Programs/custom": {
      "post": {
        "tags": [
          "Programs"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CustomProgramRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CustomProgramRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CustomProgramRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CustomProgramRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "nullable": true
          },
          "food": {
            "type": "string",
            "nullable": true
          },
          "timeInSeconds": {
            "type": "integer",
            "format": "int32"
          },
          "power": {
            "type": "integer",
            "format": "int32"
          },
          "heatingChar": {
            "type": "string",
            "nullable": true
          },
          "instructions": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "userName": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "StartHeatingRequest": {
        "type": "object",
        "properties": {
          "timeInSeconds": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "power": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "tags": [
    {
      "name": "Auth"
    },
    {
      "name": "Microwave"
    },
    {
      "name": "Programs"
    }
  ]
}